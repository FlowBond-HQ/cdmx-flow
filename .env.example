# Supabase (https://supabase.com/dashboard → Project Settings → API)
# Public URL — safe for browser if you add client-side Supabase later
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Server only — never commit real values. Set in Vercel → Settings → Environment Variables.
# Required for POST /api/waitlist (API routes use the service role to bypass RLS).
# Use either name (the code accepts both):
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
# SUPABASE_SECRET_KEY=...   # same value as "service_role" in Supabase API settings; used by Vercel’s Supabase integration

# Admin panel (/admin, optional host admin.flownation.world)
# Optional bootstrap password for steph/michelle until each user sets their own in /admin/change-password (stored in Supabase).
ADMIN_PASSWORD=
# Random string, min 16 chars — signs the admin session cookie (HS256).
ADMIN_SESSION_SECRET=
